{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "alruwaimi-law-website",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    { "pattern": "alruwaimi-law.com", "custom_domain": true },
    { "pattern": "www.alruwaimi-law.com", "custom_domain": true }
  ]
}
